PROCESSED_DATA_DIR=data/processed
DELTA_LAKE_DIR=data/processed/delta
DASHBOARD_REFRESH_SECONDS=5
STREAM_OUTPUT_MODE=console
STREAM_TRIGGER_INTERVAL=10 seconds
