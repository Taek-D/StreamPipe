PROJECT_NAME=streampipe
APP_ENV=local
SPARK_APP_NAME=streampipe
SPARK_MASTER_URL=spark://localhost:7077
SPARK_UI_URL=http://localhost:8080
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=clickstream.events
CHECKPOINT_DIR=data/checkpoints/clickstream
RAW_TAXI_DATA_DIR=data/raw/nyc_taxi
